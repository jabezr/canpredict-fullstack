# Copy this file to `.env` in the same folder as this file (backend/.env)
# and adjust anything you need. Never commit your real `.env` file.
#
# NOTE: This backend uses Open-Meteo (weather/geocoding/air quality) and
# OpenStreetMap Nominatim (reverse geocoding) — both are free, open, and
# require NO API key and NO credit card. There is nothing to sign up for.
# The settings below are all optional; sensible defaults are already
# baked into backend/config.py.

# --- Weather / geocoding / air quality provider URLs (rarely need changing) ---
# OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
# OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
# OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# --- Reverse geocoding (coordinates -> city name) ---
# Nominatim's usage policy requires a descriptive User-Agent identifying
# your application (not a default library one). Customize this if you
# plan to run this beyond local development.
# NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
NOMINATIM_USER_AGENT=CanPredict-AI-Weather/1.0 (educational project)

# --- App / server ---
APP_NAME=CanPredict AI Weather API
APP_VERSION=1.0.0
DEBUG=false

# --- CORS ---
# Comma-separated list of origins allowed to call this API.
# "null" is included because opening the frontend .html files directly
# via file:// (double-clicking them) sends an Origin header of "null" in
# some browsers. Serving the frontend via a local dev server (e.g. the
# included VSCode task, or `python -m http.server` from the frontend/
# folder) is recommended instead of file:// for full functionality
# (geolocation, clipboard, etc. behave better over http://).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,null

# --- HTTP client behaviour ---
REQUEST_TIMEOUT_SECONDS=10
MAX_RETRIES=2
RETRY_BACKOFF_SECONDS=0.5

# --- Caching (seconds) ---
CACHE_TTL_CURRENT_SECONDS=300
CACHE_TTL_FORECAST_SECONDS=900
CACHE_TTL_GEOCODE_SECONDS=86400

# --- Defaults used when a request has no ?city= or ?lat=&lon= ---
DEFAULT_CITY=Chennai
DEFAULT_LAT=13.0827
DEFAULT_LON=80.2707
DEFAULT_UNITS=metric

# --- Logging ---
LOG_LEVEL=INFO
